# ========================================
# VeriTask 3.0 — Environment Variables
# ========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control!

# --- OKX x402 API Credentials ---
# Get from: https://www.okx.com/account/my-api
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# --- Wallet Private Keys (hex, no 0x prefix) ---
# Client wallet: signs EIP-712 TransferWithAuthorization to pay Worker
CLIENT_PRIVATE_KEY=your_client_wallet_private_key_hex
# Worker wallet: receives payment (any EVM address on X Layer)
WORKER_PRIVATE_KEY=your_worker_wallet_private_key_hex
WORKER_WALLET_ADDRESS=0xYourWorkerWalletAddress

# --- Chain Config ---
# 195 = X Layer testnet, 196 = X Layer mainnet
CHAIN_INDEX=196
# Token contract on X Layer mainnet
# USDT: 0x779ded0c9e1022225f8e0630b35a9b54be713736
# USDC: 0x74b7f16337b8972027f6196a17a631ac6de26d22
# USDG: 0x4ae46a509f6b1d9056937ba4500cb143933d2dc8
TOKEN_CONTRACT_ADDRESS=0x779ded0c9e1022225f8e0630b35a9b54be713736
TOKEN_SYMBOL=USDT

# --- Reclaim Protocol (zkFetch) ---
# Get from: https://dev.reclaimprotocol.org/
RECLAIM_APP_ID=your_reclaim_app_id
RECLAIM_APP_SECRET=your_reclaim_app_secret

# --- Worker Server ---
# Local: http://127.0.0.1:8001
# Phala Cloud CVM: https://<cvm-id>-8001.dstack-pha-prod9.phala.network
WORKER_URL=http://127.0.0.1:8001

# --- Phala Cloud (optional, for CVM deployment) ---
PHALA_API_TOKEN=your_phala_api_token

# --- OnchainOS CLI ---
# Path to onchainos binary (used by Graph Anchor for broadcast)
# Find with: which onchainos
ONCHAINOS_BIN=/home/your_user/.local/bin/onchainos

# --- VTRegistry (Bidding Agent — PCEG reputation graph) ---
# Contract address on X Layer mainnet
VT_REGISTRY_ADDRESS=0x849de5a84A8619e076ef28B057b3d56c351453c1
# Deploy block number (avoids scanning empty blocks)
VT_REGISTRY_DEPLOY_BLOCK=55382189
